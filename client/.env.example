# Express URL for the Vite dev proxy (client/vite.config.js). Default: http://localhost:4000
# In `npm run dev`, the app calls /api on port 5173 and Vite forwards to this URL.
VITE_BACKEND_URL=http://localhost:4000

# Production builds: full API origin (set when you build the client).
# VITE_BACKEND_URL=https://your-api.example.com
