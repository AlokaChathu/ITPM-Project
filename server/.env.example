# Copy this file to server/.env and fill in values (required for the API to start).
# Env is always loaded from server/.env next to server.js, including when you run `npm run dev` from the repo root.

MONGODB_URI=mongodb://127.0.0.1:27017/usims

# User JWT (student/customer auth)
JWT_SECRET=your-user-jwt-secret

# Admin panel JWT (must match AdminAuth / login)
JWT_SECRET_ADMIN=your-admin-jwt-secret

# Optional
PORT=4000
